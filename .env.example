# ─── Copy this file to .env and fill in your values ───────────────────────────

# PostgreSQL connection string (get from Render / Supabase / Neon / local pgAdmin)
# Format: postgresql://USERNAME:PASSWORD@HOST:PORT/DATABASE_NAME
# Leave this BLANK for local development (it will use SQLite automatically)
DATABASE_URL=postgresql://your_user:your_password@your_host:5432/your_db_name

# Path for storing training photos and the trained model file
# Leave blank locally — defaults to ../media
MEDIA_ROOT=

# Gmail SMTP credentials for attendance email notifications
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_HOST_USER=your_email@gmail.com
EMAIL_HOST_PASSWORD=your_gmail_app_password
DEFAULT_FROM_EMAIL=Face Recognition System <your_email@gmail.com>
